import requests
import json
import os
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.image as mpimg

def load_data_from_api():
    url = "https://ll.thespacedevs.com/2.2.0/launch/upcoming"

    # Создаем папку data, если её нет
    if not os.path.exists('data'):
        os.makedirs('data')

    try:
        response = requests.get(url)
        response.raise_for_status()  # Проверка на ошибки сети
        data = response.json()

        # Сохраняем результат в файл launches.json
        with open('data/launches.json', 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=4)

        # Превращаем в DataFrame для проверки структуры
        df = pd.DataFrame(data['results'])
        print("Этап 1 завершен: Данные успешно загружены и сохранены в data/launches.json")
        print(f"Загружено записей: {len(df)}")
        return df

    except Exception as e:
        print(f"Ошибка на Этапе 1: {e}")
        return None


df_launches = load_data_from_api()


def get_pictures():
    # Создаем папку image
    if not os.path.exists('image'):
        os.makedirs('image')

    try:
        # Читаем файл из Этапа 1
        with open('data/launches.json', 'r', encoding='utf-8') as f:
            data = json.load(f)

        launches = data.get('results', [])

        for i, launch in enumerate(launches):
            # Ограничимся 50 изображениями (согласно заданию Optional)
            if i >= 50: break

            img_url = launch.get('image')

            # Обработка исключений: если URL пустой или ошибка сети
            if img_url:
                try:
                    img_data = requests.get(img_url).content
                    filename = f"image/rocket_{i}.jpg"
                    with open(filename, 'wb') as f:
                        f.write(img_data)
                    print(f"Скачано: {filename}")
                except Exception as e:
                    print(f"Не удалось скачать картинку {i}: {e}")
            else:
                print(f"Для запуска {i} изображение отсутствует.")

        print("Этап 2 завершен.")

    except FileNotFoundError:
        print("Ошибка: Файл launches.json не найден. Сначала выполните Этап 1.")


get_pictures()



def visualize_images():
    image_files = [f"image/{img}" for img in os.listdir('image') if img.endswith('.jpg')]

    if not image_files:
        print("Нет изображений для отображения.")
        return

    plt.figure(figsize=(15, 10))
    for i, img_path in enumerate(image_files[:15]):  # Покажем первые 15 для примера
        plt.subplot(3, 5, i + 1)
        img = mpimg.imread(img_path)
        plt.imshow(img)
        plt.axis('off')
        plt.title(os.path.basename(img_path), fontsize=8)

    plt.tight_layout()
    plt.show()


visualize_images()